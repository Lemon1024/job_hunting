{
  "name": "@job-tracker/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:login": "pnpm dlx eas-cli login",
    "android:apk": "pnpm dlx eas-cli build --platform android --profile preview --clear-cache",
    "android:aab": "pnpm dlx eas-cli build --platform android --profile production --clear-cache",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.0",
    "@job-tracker/core": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.46.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "^0.13.3",
    "react": "^18.3.1",
    "react-native": "0.76.9"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
